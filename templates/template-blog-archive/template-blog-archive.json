{
  "id": "page-root-blog-template",
  "type": "Page",
  "props": {},
  "styles": {},
  "children": [
    {
      "id": "section-archive-header",
      "type": "Section",
      "props": { "tagName": "section" },
      "styles": {
        "desktop": {
          "padding": "64px 32px 48px",
          "width": "100%",
          "backgroundColor": "#0f172a",
          "textAlign": "center"
        },
        "mobile": {
          "padding": "48px 20px 36px"
        }
      },
      "children": [
        {
          "id": "container-archive-header",
          "type": "Container",
          "props": { "tagName": "div", "maxWidth": "720px" },
          "styles": {
            "desktop": { "width": "100%", "margin": "0 auto", "padding": "0 24px", "boxSizing": "border-box" },
            "mobile": { "padding": "0 16px" }
          },
          "children": [
            {
              "id": "archive-title-node",
              "type": "ArchiveTitle",
              "props": { "content": "Archive", "level": "h1" },
              "styles": {
                "desktop": { "marginBottom": "12px", "fontSize": "42px", "fontWeight": "700", "color": "#ffffff", "letterSpacing": "-0.02em", "lineHeight": "1.2" },
                "mobile": { "fontSize": "32px" }
              },
              "children": []
            },
            {
              "id": "archive-desc-node",
              "type": "ArchiveDescription",
              "props": { "content": "Archive description." },
              "styles": {
                "desktop": { "fontSize": "18px", "lineHeight": "1.6", "color": "#94a3b8" },
                "mobile": { "fontSize": "16px" }
              },
              "children": []
            }
          ]
        }
      ]
    },
    {
      "id": "section-posts-loop",
      "type": "Section",
      "props": { "tagName": "section" },
      "styles": {
        "desktop": {
          "padding": "56px 32px 72px",
          "width": "100%",
          "backgroundColor": "#ffffff"
        },
        "mobile": {
          "padding": "40px 20px 56px"
        }
      },
      "children": [
        {
          "id": "query-loop-posts",
          "type": "QueryLoop",
          "props": {
            "postType": "post",
            "postsPerPage": 6,
            "orderBy": "date",
            "order": "DESC"
          },
          "styles": {
            "desktop": {
              "width": "100%",
              "maxWidth": "800px",
              "margin": "0 auto",
              "display": "flex",
              "flexDirection": "column",
              "gap": "40px"
            },
            "mobile": { "gap": "32px" }
          },
          "children": [
            {
              "id": "query-loop-template-container",
              "type": "Container",
              "props": { "tagName": "article", "maxWidth": "100%" },
              "styles": {
                "desktop": {
                  "width": "100%",
                  "padding": "0",
                  "boxSizing": "border-box",
                  "borderRadius": "12px",
                  "overflow": "hidden",
                  "border": "1px solid #e2e8f0",
                  "backgroundColor": "#ffffff",
                  "boxShadow": "0 1px 3px 0 rgba(0,0,0,0.06), 0 1px 2px -1px rgba(0,0,0,0.06)",
                  "display": "flex",
                  "flexDirection": "column",
                  "gap": "0"
                },
                "mobile": { "borderRadius": "10px" }
              },
              "children": [
                {
                  "id": "post-featured-img",
                  "type": "PostFeaturedImage",
                  "props": { "src": "", "alt": "", "size": "large", "linkToPost": true, "url": "#" },
                  "styles": {
                    "desktop": { "width": "100%", "aspectRatio": "2/1", "objectFit": "cover" },
                    "mobile": { "aspectRatio": "16/9" }
                  },
                  "children": []
                },
                {
                  "id": "post-content-wrap",
                  "type": "Container",
                  "props": { "tagName": "div", "maxWidth": "100%" },
                  "styles": {
                    "desktop": {
                      "width": "100%",
                      "padding": "32px 32px 36px",
                      "boxSizing": "border-box",
                      "display": "flex",
                      "flexDirection": "column",
                      "gap": "16px"
                    },
                    "mobile": { "padding": "24px 20px 28px" }
                  },
                  "children": [
                    {
                      "id": "post-meta-row",
                      "type": "Container",
                      "props": { "tagName": "div", "maxWidth": "100%" },
                      "styles": {
                        "desktop": {
                          "display": "flex",
                          "flexDirection": "row",
                          "flexWrap": "wrap",
                          "alignItems": "center",
                          "gap": "12px",
                          "margin": "0",
                          "padding": "0",
                          "fontSize": "13px",
                          "color": "#64748b",
                          "textTransform": "uppercase",
                          "letterSpacing": "0.04em"
                        },
                        "mobile": {}
                      },
                      "children": [
                        {
                          "id": "post-date-node",
                          "type": "PostDate",
                          "props": { "content": "Date", "format": "" },
                          "styles": { "desktop": { "fontSize": "13px", "color": "#64748b", "margin": "0" }, "mobile": {} },
                          "children": []
                        },
                        {
                          "id": "post-meta-sep",
                          "type": "Text",
                          "props": { "tagName": "span", "content": "—" },
                          "styles": { "desktop": { "fontSize": "13px", "color": "#cbd5e1", "margin": "0" }, "mobile": {} },
                          "children": []
                        },
                        {
                          "id": "post-author-node",
                          "type": "PostAuthor",
                          "props": { "content": "Author", "url": "", "showLink": true },
                          "styles": { "desktop": { "fontSize": "13px", "color": "#64748b", "margin": "0" }, "mobile": {} },
                          "children": []
                        }
                      ]
                    },
                    {
                      "id": "post-title-node",
                      "type": "PostTitle",
                      "props": { "content": "Post title", "level": "h2" },
                      "styles": {
                        "desktop": {
                          "margin": "0",
                          "fontSize": "26px",
                          "fontWeight": "700",
                          "lineHeight": "1.3",
                          "color": "#0f172a",
                          "letterSpacing": "-0.02em"
                        },
                        "mobile": { "fontSize": "22px" }
                      },
                      "children": []
                    },
                    {
                      "id": "post-excerpt-node",
                      "type": "PostExcerpt",
                      "props": { "content": "Post excerpt.", "length": 55 },
                      "styles": {
                        "desktop": {
                          "margin": "0",
                          "fontSize": "17px",
                          "lineHeight": "1.7",
                          "color": "#475569"
                        },
                        "mobile": { "fontSize": "16px" }
                      },
                      "children": []
                    },
                    {
                      "id": "post-footer-row",
                      "type": "Container",
                      "props": { "tagName": "div", "maxWidth": "100%" },
                      "styles": {
                        "desktop": {
                          "display": "flex",
                          "flexDirection": "row",
                          "alignItems": "center",
                          "justifyContent": "space-between",
                          "flexWrap": "wrap",
                          "gap": "16px",
                          "marginTop": "8px",
                          "paddingTop": "20px",
                          "borderTop": "1px solid #f1f5f9"
                        },
                        "mobile": { "paddingTop": "16px" }
                      },
                      "children": [
                        {
                          "id": "post-reading-time",
                          "type": "ReadingTime",
                          "props": { "content": "2 min read", "suffix": " min read" },
                          "styles": { "desktop": { "fontSize": "14px", "color": "#94a3b8" }, "mobile": {} },
                          "children": []
                        },
                        {
                          "id": "post-read-more",
                          "type": "Button",
                          "props": { "content": "Read more →", "href": "#", "target": "_self" },
                          "styles": {
                            "desktop": {
                              "display": "inline-block",
                              "padding": "12px 24px",
                              "backgroundColor": "#0f172a",
                              "color": "#ffffff",
                              "borderRadius": "8px",
                              "fontSize": "14px",
                              "fontWeight": "600",
                              "textDecoration": "none"
                            },
                            "mobile": { "padding": "10px 20px", "fontSize": "13px" }
                          },
                          "children": []
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "section-pagination",
      "type": "Section",
      "props": { "tagName": "section" },
      "styles": {
        "desktop": {
          "padding": "40px 32px 56px",
          "width": "100%",
          "display": "flex",
          "justifyContent": "center",
          "backgroundColor": "#f8fafc",
          "borderTop": "1px solid #e2e8f0"
        },
        "mobile": { "padding": "32px 20px 48px" }
      },
      "children": [
        {
          "id": "container-pagination",
          "type": "Container",
          "props": { "tagName": "div", "maxWidth": "100%" },
          "styles": { "desktop": { "width": "100%", "maxWidth": "800px", "padding": "0 24px" }, "mobile": { "padding": "0 16px" } },
          "children": [
            {
              "id": "pagination-node",
              "type": "Pagination",
              "props": {},
              "styles": { "desktop": { "width": "100%" }, "mobile": {} },
              "children": []
            }
          ]
        }
      ]
    },
    {
      "id": "section-no-results",
      "type": "Section",
      "props": { "tagName": "section" },
      "styles": {
        "desktop": { "padding": "80px 24px", "width": "100%", "display": "none" },
        "mobile": { "padding": "60px 16px" }
      },
      "children": [
        {
          "id": "no-results-node",
          "type": "NoResults",
          "props": { "content": "No posts found." },
          "styles": {
            "desktop": { "width": "100%", "textAlign": "center", "fontSize": "18px", "color": "#64748b", "lineHeight": "1.6" },
            "mobile": {}
          },
          "children": []
        }
      ]
    }
  ]
}
